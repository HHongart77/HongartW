# Copy this file to `.env` and replace with your actual Supabase Postgres connection string.
# Get it from: Supabase Dashboard → Project Settings → Database → Connection string (Transaction pooler recommended).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# Optional: override server port (defaults to 3000)
# PORT=3000
